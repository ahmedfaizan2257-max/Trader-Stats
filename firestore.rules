rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'trialStartDate', 'trialEndDate', 'isTrialActive', 'createdAt', 'updatedAt']) &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('name', '') is string && data.get('name', '').size() <= 128) &&
             data.trialStartDate is string && data.trialStartDate.size() <= 64 &&
             data.trialEndDate is string && data.trialEndDate.size() <= 64 &&
             data.isTrialActive is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Trade Blueprints
    function isValidTrade(data, ownerId) {
      return data.keys().hasAll(['userId', 'date', 'symbol', 'direction', 'entryPrice', 'exitPrice', 'contracts', 'pnl', 'createdAt', 'updatedAt']) &&
             data.userId == ownerId &&
             data.date is string && data.date.size() <= 32 &&
             (data.get('account', '') is string && data.get('account', '').size() <= 64) &&
             data.symbol is string && data.symbol.size() <= 32 &&
             (data.direction == 'Long' || data.direction == 'Short') &&
             data.entryPrice is number &&
             data.exitPrice is number &&
             data.contracts is number &&
             data.pnl is number &&
             (data.get('notes', '') is string && data.get('notes', '').size() <= 2048) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Journal Entry Blueprints
    function isValidJournalEntry(data, ownerId) {
      return data.keys().hasAll(['userId', 'date', 'notes', 'emotion', 'followedPlan', 'createdAt', 'updatedAt']) &&
             data.userId == ownerId &&
             data.date is string && data.date.size() <= 32 &&
             data.notes is string && data.notes.size() <= 5000 &&
             data.emotion is string && data.emotion.size() <= 32 &&
             (data.followedPlan == 'Yes' || data.followedPlan == 'Partial' || data.followedPlan == 'No') &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Path Rules
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email; // Only to satisfy possible edge cases, normally you'd just get by ID
      
      allow create: if isVerified() && request.auth.uid == userId && isValidId(userId) &&
                       isValidUser(incoming()) &&
                       incoming().keys().size() <= 7 && // email, name, trialDates(2), isActive, timestamps(2)
                       incoming().createdAt == request.time &&
                       incoming().updatedAt == request.time;
                       
      allow update: if isVerified() && request.auth.uid == userId && isValidId(userId) &&
                       isValidUser(incoming()) &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'trialStartDate', 'trialEndDate', 'isTrialActive', 'updatedAt']);
                       
      allow delete: if isVerified() && request.auth.uid == userId && isValidId(userId);

      match /trades/{tradeId} {
        allow get: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(tradeId);
        allow list: if isVerified() && request.auth.uid == userId && resource.data.userId == request.auth.uid;
        
        allow create: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(tradeId) &&
                         isValidTrade(incoming(), request.auth.uid) &&
                         incoming().keys().size() <= 12 &&
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time;
                         
        allow update: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(tradeId) &&
                         isValidTrade(incoming(), request.auth.uid) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['date', 'account', 'symbol', 'direction', 'entryPrice', 'exitPrice', 'contracts', 'pnl', 'notes', 'updatedAt']);
                         
        allow delete: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(tradeId);
      }

      match /journalEntries/{journalEntryId} {
        allow get: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(journalEntryId);
        allow list: if isVerified() && request.auth.uid == userId && resource.data.userId == request.auth.uid;
        
        allow create: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(journalEntryId) &&
                         isValidJournalEntry(incoming(), request.auth.uid) &&
                         incoming().keys().size() <= 7 &&
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time;
                         
        allow update: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(journalEntryId) &&
                         isValidJournalEntry(incoming(), request.auth.uid) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['date', 'notes', 'emotion', 'followedPlan', 'updatedAt']);
                         
        allow delete: if isVerified() && request.auth.uid == userId && isValidId(userId) && isValidId(journalEntryId);
      }
    }
  }
}
