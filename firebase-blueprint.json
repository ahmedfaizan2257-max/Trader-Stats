{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and trial status.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "trialStartDate": { "type": "string" },
        "trialEndDate": { "type": "string" },
        "isTrialActive": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "trialStartDate", "trialEndDate", "isTrialActive", "createdAt", "updatedAt"]
    },
    "Trade": {
      "title": "Trade Execution",
      "description": "Stores an individual trade execution.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns the trade" },
        "date": { "type": "string" },
        "account": { "type": "string" },
        "symbol": { "type": "string" },
        "direction": { "type": "string", "enum": ["Long", "Short"] },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "contracts": { "type": "number" },
        "pnl": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "date", "symbol", "direction", "entryPrice", "exitPrice", "contracts", "pnl", "createdAt", "updatedAt"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "Stores a daily journal entry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns the journal entry" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "emotion": { "type": "string" },
        "followedPlan": { "type": "string", "enum": ["Yes", "Partial", "No"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "date", "notes", "emotion", "followedPlan", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile documents"
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": { "$ref": "#/entities/Trade" },
      "description": "Trades belonging to a specific user"
    },
    "/users/{userId}/journalEntries/{journalEntryId}": {
      "schema": { "$ref": "#/entities/JournalEntry" },
      "description": "Journal entries belonging to a specific user"
    }
  }
}
